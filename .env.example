# ---------------- Runtime ----------------
ENVIRONMENT=production
EXTRA_CORS_ORIGINS=

# ---------------- Storage (Cloudflare R2) ----------------
R2_ENDPOINT_URL=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your-access-key-id>
R2_SECRET_ACCESS_KEY=<your-secret-access-key>
R2_BUCKET_NAME=<your-bucket-name>
PUBLIC_URL_PREFIX=https://cdn.example.com

# ---------------- Image conversion ----------------
CONVERSION_SERVICE_URL=http://webp-converter:8090

# ---------------- Auth ----------------
API_KEY=<long-random-string-shared-with-authorized-users>
ALLOWED_SITES=dokimotes,dokinomicon

# ---------------- Cloudflare Turnstile ----------------
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=<from-cloudflare-dashboard>
TURNSTILE_SITE_KEY=<from-cloudflare-dashboard>

# ---------------- Discord notifications ----------------
DISCORD_WEBHOOK=https://example.com
ADMIN_URL=https://api.duck-automata.com/content-manager/
IMAGE_UPLOAD_NOTIFY_INTERVAL_SECONDS=600
